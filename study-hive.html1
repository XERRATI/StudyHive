  <button class="misc-btn dock-item" id="musicBtn" style="bottom:14px; top:auto; left:1730px; position:fixed;">🎵 Music</button>
  <div class="misc-panel" id="musicPanel" style="bottom:58px; top:auto; left:1730px;">
    <h4>Lofi Player</h4>
    <div class="lofi-player" id="lofiPlayer" style="position:static; width:auto; box-shadow:none; background:none; padding:0;">
      <div class="vinyl" id="vinylSpinner"></div>
      <div class="lofi-tracks">
        <button class="lofi-track-btn" data-track="hive">🎹 Hive Hum</button>
        <button class="lofi-track-btn" data-track="rain">🌧️ Study Rain</button>
        <button class="lofi-track-btn" data-track="dawn">🎸 Dawn Focus</button>
        <button class="lofi-track-btn" data-track="ocean">🌊 Ocean Waves</button>
        <button class="lofi-track-btn" data-track="forest">🌲 Forest</button>
        <button class="lofi-track-btn" data-track="white">📻 White Noise</button>
      </div>
    </div>
  </div>

  <button class="misc-btn dock-item" id="feedbackBtn">💬 Feedback</button>
  <div class="misc-panel" id="feedbackPanel">
    <h4>Talk to the Hive</h4>
    <p style="font-size:12px; color:var(--brown); margin-bottom:10px; line-height:1.4;">Bug, idea, or just want to say hi — it comes straight to us.</p>
    <textarea id="feedbackText" placeholder="What's on your mind?" rows="4" style="width:100%; border-radius:12px; border:1.5px solid var(--taupe); padding:10px; font-family:'Fredoka',sans-serif; font-size:13px; resize:vertical; margin-bottom:8px;"></textarea>
    <input type="email" id="feedbackEmail" placeholder="Your email (optional, so we can reply)" style="width:100%; border-radius:12px; border:1.5px solid var(--taupe); padding:9px 10px; font-family:'Fredoka',sans-serif; font-size:13px; margin-bottom:10px;">
    <button class="breathing-action-btn" id="feedbackSendBtn" style="width:100%;">Send to the Hive 🐝</button>
    <div id="feedbackStatus" style="font-size:11px; color:var(--brown); margin-top:8px; text-align:center;"></div>
  </div>

  <button class="misc-btn dock-item" id="tipsBtn">💡 Study Tips</button>
  <div class="misc-panel" id="tipsPanel" style="text-align:center;">
    <h4>Hive Wisdom</h4>
    <div id="tipText" style="font-size:14px; color:var(--deep-brown); font-weight:600; line-height:1.5; min-height:70px; display:flex; align-items:center; justify-content:center; padding:6px 4px;"></div>
    <button class="breathing-action-btn secondary" id="tipNextBtn" style="width:100%; margin-top:8px;">Another one 🔄</button>
  </div>

  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <clipPath id="bee-body-clip" clipPathUnits="userSpaceOnUse">
        <ellipse cx="23" cy="26" rx="12" ry="9"></ellipse>
      </clipPath>
    </defs>
  </svg>

  <div class="bee-wrap bee-1">
    <svg class="bee-bob" viewBox="0 0 46 46" xmlns="http://www.w3.org/2000/svg">
      <ellipse class="wing" cx="14" cy="18" rx="9" ry="6" fill="rgba(255,255,255,0.75)" stroke="#d3b995" stroke-width="1"></ellipse>
      <ellipse class="wing wing-right" cx="32" cy="18" rx="9" ry="6" fill="rgba(255,255,255,0.75)" stroke="#d3b995" stroke-width="1"></ellipse>
      <ellipse cx="23" cy="26" rx="12" ry="9" fill="#f4c430"></ellipse>
      <g clip-path="url(#bee-body-clip)">
        <rect x="11.5" y="17" width="4" height="18" fill="#2b2b2b"></rect>
        <rect x="19" y="17" width="4" height="18" fill="#2b2b2b"></rect>
        <rect x="26.5" y="17" width="4" height="18" fill="#2b2b2b"></rect>
      </g>
      <circle cx="33" cy="22" r="5" fill="#2b2b2b"></circle>
      <circle cx="34.5" cy="20.5" r="1" fill="#fff"></circle>
      <path d="M30 17 L27 12" stroke="#2b2b2b" stroke-width="1.4" stroke-linecap="round"></path>
      <path d="M35 17 L37 12" stroke="#2b2b2b" stroke-width="1.4" stroke-linecap="round"></path>
    </svg>
